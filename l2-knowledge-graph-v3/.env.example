# L2 Knowledge Graph Layer — Environment Configuration
# Copy to .env and fill in values

# --- Neo4j ---
NEO4J_URI=bolt+s://localhost:7687
NEO4J_READ_USER=pipeline_reader
NEO4J_READ_PASSWORD=changeme
NEO4J_WRITE_USER=schema_writer
NEO4J_WRITE_PASSWORD=changeme
NEO4J_DATABASE=neo4j
NEO4J_MAX_POOL_SIZE=50
NEO4J_ENCRYPTED=true

# --- PostgreSQL (audit) ---
PG_AUDIT_DSN=postgresql+asyncpg://l2_audit:changeme@localhost:5432/l2_audit
PG_POOL_MIN=5
PG_POOL_MAX=20

# --- Redis (cache) ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# --- pgvector (embeddings) ---
PG_VECTOR_DSN=postgresql+asyncpg://l2_embed:changeme@localhost:5432/l2_embeddings

# --- Vault ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-token
VAULT_SECRET_PATH=secret/data/l2-knowledge-graph
VAULT_ENABLED=false

# --- API Auth ---
SERVICE_TOKEN_SECRET=change-this-to-a-long-random-string
ALLOWED_SERVICE_IDS=l1-identity,l3-retrieval,l4-policy,l6-validation,l8-audit

# --- Embedding ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_API_BASE=https://api.openai.com/v1

# --- LLM (description generation) ---
LLM_API_KEY=sk-xxx
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- App ---
APP_ENV=development
APP_PORT=8002
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=600
